---
import { Icon } from "astro-icon/components";
import { withBase } from "../lib/withBase";
import { EMAIL, LINKEDIN } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__name">Miranda Morton</p>
      <p class="site-footer__tag">Architectural Designer &amp; Drafter</p>
    </div>
    <nav class="site-footer__links">
      <a href={`mailto:${EMAIL}`}><Icon name="lucide:mail" />Email</a>
      <a href={LINKEDIN} target="_blank" rel="noopener"
        ><Icon name="simple-icons:linkedin" />LinkedIn</a
      >
      <a href={withBase("/contact")}
        >Contact<Icon name="lucide:arrow-right" class="footer-arrow" /></a
      >
    </nav>
  </div>
  <p class="site-footer__copy">© {year} Miranda Morton. All rights reserved.</p>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark);
    color: #cdcbe0;
    padding: 3rem 0 1.5rem;
    margin-top: 2rem;
  }
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: space-between;
    align-items: center;
  }
  .site-footer__name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: #fff;
    margin: 0;
  }
  .site-footer__tag {
    margin: 0.15rem 0 0;
    font-size: 0.9rem;
    color: var(--lavender);
  }
  .site-footer__links {
    display: flex;
    gap: 1.5rem;
  }
  .site-footer__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--lavender);
    font-weight: 500;
  }
  .site-footer__links a:hover {
    color: var(--cyan);
  }
  .site-footer__links svg {
    width: 1.05em;
    height: 1.05em;
    transition: transform 0.2s ease;
  }
  .site-footer__links a:hover svg {
    transform: scale(1.12);
  }
  .site-footer__links a:hover .footer-arrow {
    transform: translateX(3px);
  }
  .site-footer__copy {
    text-align: center;
    margin: 2rem 0 0;
    font-size: 0.82rem;
    color: #7c7a98;
  }
</style>
