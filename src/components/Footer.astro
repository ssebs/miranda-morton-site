---
import { Icon } from "astro-icon/components";
import { withBase } from "../lib/withBase";
import { EMAIL, LINKEDIN, NAV_LINKS } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__name">Miranda Morton</p>
      <p class="site-footer__tag">Architectural Designer &amp; Drafter</p>
    </div>
    <nav class="site-footer__nav">
      {NAV_LINKS.map((l) => <a href={withBase(l.href)}>{l.label}</a>)}
    </nav>
    <div class="site-footer__social">
      <a href={`mailto:${EMAIL}`} aria-label="Email">
        <Icon name="lucide:mail" />
      </a>
      <a href={LINKEDIN} target="_blank" rel="noopener" aria-label="LinkedIn">
        <Icon name="simple-icons:linkedin" />
      </a>
    </div>
  </div>
  <p class="site-footer__copy">© {year} Miranda Morton. All rights reserved.</p>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark);
    color: #cdcbe0;
    padding: 3rem 0 1.5rem;
    margin-top: 2rem;
  }
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: space-between;
    align-items: center;
  }
  .site-footer__name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: #fff;
    margin: 0;
  }
  .site-footer__tag {
    margin: 0.15rem 0 0;
    font-size: 0.9rem;
    color: var(--lavender);
  }
  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .site-footer__nav a {
    color: var(--lavender);
    font-weight: 500;
  }
  .site-footer__nav a:hover {
    color: var(--cyan);
  }
  .site-footer__social {
    display: flex;
    gap: 1rem;
  }
  .site-footer__social a {
    display: inline-flex;
    color: var(--lavender);
  }
  .site-footer__social a:hover {
    color: var(--cyan);
  }
  .site-footer__social svg {
    width: 1.35rem;
    height: 1.35rem;
    transition: transform 0.2s ease;
  }
  .site-footer__social a:hover svg {
    transform: scale(1.15);
  }
  .site-footer__copy {
    text-align: center;
    margin: 2rem 0 0;
    font-size: 0.82rem;
    color: #7c7a98;
  }
</style>
