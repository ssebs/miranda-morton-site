---
interface Cta {
  href: string;
  label: string;
  style?: "primary" | "ghost";
  external?: boolean;
}

interface Props {
  name?: string;
  title?: string;
  image?: string;
  ctas?: Cta[];
}

const {
  name = "Miranda Morton",
  title = "Architectural Designer & Drafter",
  image = "/img/miranda-portrait.svg",
  ctas = [
    { href: "/portfolio", label: "View Portfolio", style: "primary" },
    { href: "/about", label: "About & Resume", style: "ghost" },
    {
      href: "https://www.linkedin.com/in/miranda-morton-34b00230a/",
      label: "LinkedIn",
      style: "ghost",
      external: true,
    },
  ],
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__text">
      <p class="eyebrow">Proportion · Clarity · Craft</p>
      <h1>{name}</h1>
      <p class="hero__title">{title}</p>
      <div class="hero__ctas">
        {
          ctas.map((c) => (
            <a
              href={c.href}
              class:list={[
                "btn",
                c.style === "ghost" ? "btn--ghost" : "btn--primary",
              ]}
              {...c.external ? { target: "_blank", rel: "noopener" } : {}}
            >
              {c.label}
            </a>
          ))
        }
      </div>
    </div>
    <div class="hero__media">
      <img src={image} alt={`Portrait of ${name}`} width="520" height="640" />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(160deg, var(--bg-alt), #fff 70%);
    border-bottom: 1px solid var(--border);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .hero__title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: var(--accent-strong);
    font-weight: 500;
    margin: 0 0 1.75rem;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
  }
  @media (max-width: 760px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__media {
      order: -1;
      max-width: 360px;
    }
  }
</style>
