---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { withBase } from "../lib/withBase";
import { LINKEDIN } from "../lib/site";
import portrait from "../assets/miranda-headshot.jpg";
---

<section class="hero">
  <div class="hero__grid-bg" aria-hidden="true"></div>
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__text">
      <p class="eyebrow hero__eyebrow">Design · Documentation · Detail</p>
      <h1 class="hero__name">Miranda Morton</h1>
      <p class="hero__title">Architectural Designer</p>
      <p class="hero__blurb">
        Master of Architecture graduate with professional experience in multifamily housing - from schematic design through construction administration.
      </p>
      <div class="hero__ctas">
        <a href={withBase("/portfolio")} class="btn btn--primary"
          >View Portfolio<Icon name="lucide:arrow-right" class="cta-arrow" /></a
        >
        <a href={withBase("/about")} class="btn btn--ghost"
          >About &amp; Resume<Icon name="lucide:arrow-right" class="cta-arrow" /></a
        >
        <a href={LINKEDIN} target="_blank" rel="noopener" class="btn btn--ghost">
          <Icon name="simple-icons:linkedin" />LinkedIn
        </a>
      </div>
    </div>

    <div class="hero__media">
      <span class="hero__frame" aria-hidden="true"></span>
      <span class="hero__accent" aria-hidden="true"></span>
      <Image src={portrait} alt="Portrait of Miranda Morton" width={520} height={640} />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        120% 90% at 85% 0%,
        rgba(144, 122, 214, 0.18),
        transparent 55%
      ),
      linear-gradient(160deg, var(--bg-alt), #fff 72%);
    border-bottom: 1px solid var(--border);
  }

  /* Faint blueprint grid */
  .hero__grid-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
        to right,
        rgba(79, 81, 140, 0.06) 1px,
        transparent 1px
      ),
      linear-gradient(to bottom, rgba(79, 81, 140, 0.06) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(80% 70% at 70% 30%, #000 30%, transparent 78%);
    pointer-events: none;
  }
  .hero__glow {
    position: absolute;
    width: 460px;
    height: 460px;
    right: -120px;
    top: -160px;
    background: radial-gradient(circle, rgba(127, 222, 255, 0.35), transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }

  .hero__text > * {
    opacity: 0;
    transform: translateY(14px);
    animation: rise 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  .hero__eyebrow {
    animation-delay: 0.05s;
  }
  .hero__name {
    animation-delay: 0.13s;
  }
  .hero__title {
    animation-delay: 0.21s;
  }
  .hero__blurb {
    animation-delay: 0.29s;
  }
  .hero__ctas {
    animation-delay: 0.37s;
  }

  .hero__name {
    font-size: clamp(2.6rem, 6.5vw, 4.4rem);
    background: linear-gradient(120deg, var(--navy) 30%, var(--indigo));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.35rem;
  }
  .hero__title {
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    color: var(--accent-strong);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .hero__blurb {
    color: var(--text-muted);
    max-width: 46ch;
    margin: 0 0 1.9rem;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Portrait with layered frame + offset accent block */
  .hero__media {
    position: relative;
    isolation: isolate;
  }
  .hero__media img {
    position: relative;
    z-index: 2;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: 0 24px 50px rgba(44, 42, 74, 0.28);
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero__media:hover img {
    transform: translateY(-6px);
  }
  .hero__accent {
    position: absolute;
    z-index: 1;
    inset: 22px -20px -22px 22px;
    border-radius: var(--radius);
    background: linear-gradient(135deg, var(--cyan), var(--lavender));
    opacity: 0.55;
  }
  .hero__frame {
    position: absolute;
    z-index: 3;
    inset: -14px -14px auto auto;
    width: 92px;
    height: 92px;
    border-top: 2px solid var(--purple);
    border-right: 2px solid var(--purple);
    border-top-right-radius: 6px;
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 760px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__text {
      width: fit-content;
      margin-inline: auto;
    }
    .hero__media {
      order: -1;
      max-width: 340px;
      margin-inline: auto;
    }
    .hero__accent {
      inset: 18px -14px -18px 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__text > * {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .btn::after {
      display: none;
    }
  }
</style>
