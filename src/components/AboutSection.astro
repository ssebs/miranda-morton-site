---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { withBase } from "../lib/withBase";
import aboutImage from "../assets/miranda-about.svg";
interface Props {
  /** "compact" for the home-page teaser, "full" for the About page. */
  variant?: "compact" | "full";
  image?: ImageMetadata;
  showResumeCta?: boolean;
}

const {
  variant = "compact",
  image = aboutImage,
  showResumeCta = true,
} = Astro.props;
---

<div class:list={["about", `about--${variant}`]}>
  <div class="about__media">
    <Image src={image} alt="Miranda Morton" loading="lazy" />
  </div>
  <div class="about__text">
    <p class="eyebrow">About</p>
    <h2>Architecture rooted in classical discipline</h2>
    <p>
      I'm an architectural designer with a Master of Architecture from the
      University of Colorado Denver. At JLA Architects I work on multifamily
      housing across market-rate, student, and affordable senior projects,
      contributing through every phase from schematic design to construction
      administration. My graduate studio work explores classical and civic
      design, from rotundas and porticos to carefully detailed building
      envelopes.
    </p>
    {
      variant === "full" && (
        <p>
          I draw and detail by hand as readily as I model in Revit and document
          in AutoCAD, and I render in Twinmotion and Photoshop. The thread
          through my work is care for proportion, hierarchy, and how a building
          is actually put together.
        </p>
      )
    }
    {
      showResumeCta && (
        <div class="about__ctas">
          <a href={withBase("/about")} class="btn btn--primary">
            About &amp; Resume
          </a>
        </div>
      )
    }
  </div>
</div>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  /* About page: text on the left (following her gaze), photo on the right. */
  .about--full {
    grid-template-columns: 1.2fr 0.8fr;
  }
  .about--full .about__text {
    order: 1;
  }
  .about--full .about__media {
    order: 2;
  }
  .about__media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
  }
  .about__text h2 {
    margin-top: 0.25rem;
  }
  .about__ctas {
    margin-top: 1.5rem;
  }
  @media (max-width: 760px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__media {
      max-width: 320px;
    }
  }
</style>
