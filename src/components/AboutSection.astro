---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import { withBase } from "../lib/withBase";
import aboutImage from "../assets/miranda-about.svg";
interface Props {
  /** "compact" for the home-page teaser, "full" for the About page. */
  variant?: "compact" | "full";
  image?: ImageMetadata;
  showResumeCta?: boolean;
}

const {
  variant = "compact",
  image = aboutImage,
  showResumeCta = true,
} = Astro.props;
---

<div class:list={["about", `about--${variant}`]}>
  <div class="about__media">
    <Image src={image} alt="Miranda Morton" loading="lazy" />
  </div>
  <div class="about__text">
    <h2>Architecture grounded in detail and documentation</h2>
    <p>
      I'm an architectural designer with a Master of Architecture from the
      University of Colorado Denver. At JLA Architects I've contributed to
      multifamily housing projects across market-rate, student, and affordable
      senior typologies, working through every phase from schematic design to
      construction administration. My studio work ranges from single-family
      residences to civic visitor centers, with an emphasis on proportion and
      hierarchy.
    </p>
    {
      variant === "full" && (
        <p>
          I draw by hand, work primarily in Revit and AutoCAD, and render in Twinmotion and Photoshop. What runs through all of it is an attention to how a building is experienced and assembled.
        </p>
      )
    }
    {
      showResumeCta && (
        <div class="about__ctas">
          <a href={withBase("/about")} class="btn btn--primary">
            About &amp; Resume<Icon name="lucide:arrow-right" class="cta-arrow" />
          </a>
        </div>
      )
    }
  </div>
</div>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  /* About page: text on the left (following her gaze), photo on the right. */
  .about--full {
    grid-template-columns: 1.2fr 0.8fr;
  }
  .about--full .about__text {
    order: 1;
  }
  .about--full .about__media {
    order: 2;
  }
  .about__media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
  }
  .about__text h2 {
    margin-top: 0.25rem;
  }
  .about__ctas {
    margin-top: 1.5rem;
  }
  @media (max-width: 760px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__media {
      max-width: 320px;
    }
  }
</style>
