---
interface Props {
  /** "compact" for the home-page teaser, "full" for the About page. */
  variant?: "compact" | "full";
  image?: string;
  showResumeCta?: boolean;
}

const {
  variant = "compact",
  image = "/img/miranda-about.svg",
  showResumeCta = true,
} = Astro.props;
---

<div class:list={["about", `about--${variant}`]}>
  <div class="about__media">
    <img src={image} alt="Miranda Morton" loading="lazy" />
  </div>
  <div class="about__text">
    <p class="eyebrow">About</p>
    <h2>Architecture rooted in classical discipline</h2>
    <p>
      Miranda Morton is an architectural designer and drafter with a Master of
      Architecture from the University of Colorado Denver. She works on
      multifamily and affordable housing at JLA Architects, and her studio work
      explores classical and civic design — rotundas, porticos, and carefully
      detailed building envelopes.
    </p>
    {
      variant === "full" && (
        <p>
          She draws and details by hand as readily as she models in Revit, and
          documents in AutoCAD and Twinmotion. The thread through her work is a
          care for proportion, hierarchy, and how a building is actually put
          together.
        </p>
      )
    }
    {
      showResumeCta && (
        <div class="about__ctas">
          <a href="/about" class="btn btn--primary">
            Download Resume
          </a>
        </div>
      )
    }
  </div>
</div>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  .about__media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
  }
  .about__text h2 {
    margin-top: 0.25rem;
  }
  .about__ctas {
    margin-top: 1.5rem;
  }
  @media (max-width: 760px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__media {
      max-width: 320px;
    }
  }
</style>
