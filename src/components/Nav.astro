---
import { withBase } from "../lib/withBase";
import { NAV_LINKS as links } from "../lib/site";
const strip = (p: string) => p.replace(/\/$/, "") || "/";
const path = strip(Astro.url.pathname);
---

<header class="site-nav">
  <div class="container site-nav__inner">
    <a href={withBase("/")} class="site-nav__brand">
      <span class="site-nav__mark">MM</span>
      <span class="site-nav__name">Miranda&nbsp;Morton</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="site-nav__checkbox" />
    <label for="nav-toggle" class="site-nav__burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav__links">
      {
        links.map((l) => (
          <a
            href={withBase(l.href)}
            class:list={["site-nav__link", { "is-active": path === strip(withBase(l.href)) }]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  /* Gradient hairline along the very top */
  .site-nav::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--lavender),
      var(--purple),
      var(--indigo),
      var(--cyan)
    );
  }
  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 66px;
  }
  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--navy);
  }
  .site-nav__mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: linear-gradient(135deg, var(--purple), var(--indigo));
    color: #fff;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    box-shadow: 0 4px 12px rgba(79, 81, 140, 0.32);
    transition: transform 0.2s ease;
  }
  .site-nav__brand:hover .site-nav__mark {
    transform: rotate(-6deg) scale(1.06);
  }
  .site-nav__name {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .site-nav__links {
    display: flex;
    gap: 1.75rem;
  }
  .site-nav__link {
    position: relative;
    color: var(--text);
    font-weight: 500;
    font-size: 0.98rem;
    padding-block: 0.3rem;
  }
  /* Sliding underline */
  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 100%;
    background: linear-gradient(90deg, var(--purple), var(--cyan));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .site-nav__link:hover {
    color: var(--accent-strong);
  }
  .site-nav__link:hover::after {
    transform: scaleX(1);
  }
  .site-nav__link.is-active {
    color: var(--accent-strong);
  }
  .site-nav__link.is-active::after {
    transform: scaleX(1);
  }

  /* Mobile */
  .site-nav__checkbox,
  .site-nav__burger {
    display: none;
  }
  .site-nav__burger {
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
  }
  .site-nav__burger span {
    width: 24px;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
  }

  @media (max-width: 720px) {
    .site-nav__burger {
      display: flex;
    }
    .site-nav__links {
      position: absolute;
      top: 66px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: #fff;
      border-bottom: 1px solid var(--border);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .site-nav__link {
      padding: 0.9rem 1.25rem;
      border-bottom: 1px solid var(--border);
    }
    .site-nav__checkbox:checked ~ .site-nav__links {
      max-height: 320px;
    }
  }
</style>
