---
import { Icon } from "astro-icon/components";
import { withBase } from "../lib/withBase";
import { EMAIL } from "../lib/site";
// Recreated from ssebs.com/contact — uses FormSubmit.co (no backend needed).
const action = `https://formsubmit.co/${EMAIL}`;
// Where FormSubmit redirects after a successful submit. FormSubmit needs an
// absolute URL, but we don't know the serving domain at build time (and don't
// want to hardcode it) — so resolve it against the live origin in the browser.
const nextPath = withBase("/contact?sent=1");
---

<form action={action} method="POST" class="cform">
  <div class="cform__field">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" placeholder="Jane Doe" required />
  </div>

  <div class="cform__field">
    <label for="email">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="jane@example.com"
      required
    />
  </div>

  <div class="cform__field">
    <label for="_subject">Subject</label>
    <input
      type="text"
      id="_subject"
      name="_subject"
      placeholder="Let's work together"
      required
    />
  </div>

  <div class="cform__field">
    <label for="message">Message</label>
    <textarea
      id="message"
      name="message"
      rows="8"
      placeholder="Tell me about the role or project…"
      required></textarea>
  </div>

  <!-- FormSubmit configuration -->
  <input type="hidden" name="_captcha" value="false" />
  <input type="hidden" name="_next" id="cform-next" value={nextPath} />

  <button type="submit" class="btn btn--primary cform__submit">
    Send Message<Icon name="lucide:send" />
  </button>
</form>

<script define:vars={{ nextPath }}>
  // Resolve _next against the current origin so the post-submit redirect lands
  // back on whatever domain is serving the page, no build-time domain needed.
  document.getElementById("cform-next").value = new URL(
    nextPath,
    window.location.origin,
  ).href;
</script>

<style>
  .cform {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 640px;
  }
  .cform__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cform__field label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--navy);
  }
  .cform input,
  .cform textarea {
    font: inherit;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: #fff;
    color: var(--text);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .cform input:focus,
  .cform textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(144, 122, 214, 0.2);
  }
  .cform textarea {
    resize: vertical;
  }
  .cform__submit {
    align-self: flex-start;
    margin-top: 0.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cform__submit svg {
    width: 1.05em;
    height: 1.05em;
    transition: transform 0.2s ease;
  }
  .cform__submit:hover svg {
    transform: translate(3px, -3px);
  }
</style>
