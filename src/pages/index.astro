---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import AboutSection from "../components/AboutSection.astro";
import ContactForm from "../components/ContactForm.astro";
import { withBase } from "../lib/withBase";
import heroPhoto from "../assets/miranda-headshot.jpg";
import aboutTeaserPhoto from "../assets/miranda-2.jpeg";

const projects = await getCollection("projects");
---

<Layout>
  <Hero image={heroPhoto} />

  <section class="section" id="work">
    <div class="container">
      <p class="eyebrow">Selected Work</p>
      <h2>Recent projects</h2>
      <p class="lede">
        Professional work at JLA Architects and academic projects spanning hand-drawn details to commercial designs.
      </p>
      <div class="work__grid">
        <ProjectGrid projects={projects} split={true} limit={2} />
      </div>
      <div class="work__cta">
        <a href={withBase("/projects")} class="btn btn--primary">View all projects</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <AboutSection variant="compact" image={aboutTeaserPhoto} />
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container">
      <p class="eyebrow">Get in Touch</p>
      <h2>Let's work together</h2>
      <p class="lede">
        Hiring, or have a project in mind? Send a note and I'll reply soon.
      </p>
      <div class="home-contact">
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>

<style>
  .work__grid {
    margin-top: 2.5rem;
  }
  .work__cta {
    margin-top: 2.5rem;
    text-align: center;
  }
  .home-contact {
    margin-top: 2rem;
  }
</style>
