---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import PdfEmbed from "../../components/PdfEmbed.astro";
import Lightbox from "../../components/Lightbox.astro";
import { withBase } from "../../lib/withBase";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, summary, keyInsights, coverImage, gallery, fullDocsPdf } =
  project.data;
const { Content } = await render(project);
---

<Layout title={`${title} - Miranda Morton`} description={summary}>
  <article class="project">
    <header class="project__hero">
      <div class="container project__hero-inner">
        <div class="project__hero-text">
          <a href={withBase("/projects")} class="project__back">← All projects</a>
          <h1>{title}</h1>
          <p class="lede">{summary}</p>
        </div>
        <button
          type="button"
          class="project__hero-media"
          data-lightbox-trigger
          aria-label={`View ${title} cover image`}
        >
          <Image src={coverImage} alt={title} />
        </button>
      </div>
    </header>

    <div class="container project__body">
      {
        keyInsights.length > 0 && (
          <aside class="project__insights">
            <h2>Role & contributions</h2>
            <ul>
              {keyInsights.map((insight) => (
                <li>{insight}</li>
              ))}
            </ul>
          </aside>
        )
      }

      <div class="project__prose">
        <Content />
      </div>
    </div>

    {
      gallery.length > 0 && (
        <div class="container project__gallery">
          {gallery.map((src, i) => (
            <button
              type="button"
              class="project__gallery-item"
              data-lightbox-trigger
              aria-label={`View gallery image ${i + 1} of ${gallery.length}`}
            >
              <Image src={src} alt={`${title} — gallery image ${i + 1}`} loading="lazy" />
            </button>
          ))}
        </div>
      )
    }

    <div class="container project__docs">
      {
        fullDocsPdf && (
          <div class="project__docs-embed">
            <h2>Full documentation</h2>
            <PdfEmbed
              src={fullDocsPdf}
              title={`${title} — full documentation`}
              ratio="wide"
              downloadLabel="Download Full Documentation (PDF)"
            />
          </div>
        )
      }
    </div>

    <Lightbox label={`${title} images`} />
  </article>
</Layout>

<style>
  .project__hero {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding-block: clamp(2rem, 6vw, 4rem);
  }
  .project__hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .project__back {
    display: inline-block;
    margin-bottom: 1rem;
    font-weight: 600;
    font-size: 0.92rem;
  }
  .project__hero-media {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    border-radius: var(--radius);
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .project__hero-media:hover {
    transform: translateY(-3px);
  }
  .project__hero-media:focus-visible {
    outline: 2px solid var(--accent-strong);
    outline-offset: 3px;
  }
  .project__hero-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    aspect-ratio: 16 / 9;
    max-height: 40vh;
    object-fit: cover;
  }
  .project__body {
    display: grid;
    grid-template-columns: 0.9fr 1.6fr;
    gap: clamp(2rem, 5vw, 4rem);
    margin-block: clamp(2.5rem, 6vw, 4rem);
  }
  .project__insights {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    align-self: start;
    position: sticky;
    top: 84px;
  }
  .project__insights h2 {
    font-size: 1.15rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--font-sans);
    color: var(--accent-strong);
  }
  .project__insights ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
  }
  .project__insights li {
    margin-bottom: 0.6rem;
  }
  .project__prose :global(p) {
    font-size: 1.05rem;
  }
  .project__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--gap);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .project__gallery-item {
    position: relative;
    display: block;
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    aspect-ratio: 4 / 3;
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-alt);
    overflow: hidden;
    box-shadow: var(--shadow);
    cursor: zoom-in;
    font: inherit;
    color: inherit;
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.2s ease;
  }
  .project__gallery-item:focus-visible {
    outline: 2px solid var(--accent-strong);
    outline-offset: 3px;
  }
  .project__gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .project__gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(44, 42, 74, 0.16);
  }
  .project__gallery-item:hover img {
    transform: scale(1.04);
  }
  /* corner accent echoing the hero frame */
  .project__gallery-item::after {
    content: "";
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 26px;
    height: 26px;
    border-top: 2px solid var(--purple);
    border-right: 2px solid var(--purple);
    border-top-right-radius: 4px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .project__gallery-item:hover::after {
    opacity: 0.7;
  }

  .project__docs {
    margin-bottom: clamp(3rem, 8vw, 5rem);
  }
  @media (max-width: 820px) {
    .project__hero-inner {
      grid-template-columns: 1fr;
    }
    .project__body {
      grid-template-columns: 1fr;
    }
    .project__insights {
      position: static;
    }
  }
</style>

