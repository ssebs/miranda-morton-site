---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectGrid from "../../components/ProjectGrid.astro";

const projects = await getCollection("projects");
---

<Layout title="Projects - Miranda Morton">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Projects</p>
      <h1>Full project list</h1>
      <p class="lede">
        Every project, with a short summary and key insights. Open any one for
        full documentation and explanation. Note that professional projects are
        shown with select work samples only - full documentation is not
        available out of respect for firm and client confidentiality.
      </p>
      <div class="projects__grid">
        <ProjectGrid projects={projects} split={false} />
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects__grid {
    margin-top: 2.5rem;
  }
</style>
