---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import { Icon } from "astro-icon/components";
import { EMAIL, LINKEDIN } from "../lib/site";
---

<Layout title="Contact - Miranda Morton">
  <section class="section">
    <div class="container contact">
      <p class="eyebrow">Contact</p>
      <h1>Let's talk</h1>
      <p class="lede">
        Whether it's a role, a project, or a question about my work — I'd love to
        hear from you. Fill out the form below or reach me directly.
      </p>

      <p class="contact__success" id="contact-success" hidden>
        Thanks for reaching out! Your message has been sent — I'll be in touch
        soon.
      </p>
      <script is:inline>
        if (new URLSearchParams(location.search).get("sent") === "1") {
          document.getElementById("contact-success")?.removeAttribute("hidden");
        }
      </script>

      <div class="contact__grid">
        <ContactForm />
        <aside class="contact__direct">
          <h3>Direct</h3>
          <p>
            <a href={`mailto:${EMAIL}`} class="contact__link"
              ><Icon name="lucide:mail" />{EMAIL}</a
            >
          </p>
          <p>
            <a href={LINKEDIN} target="_blank" rel="noopener" class="contact__link"
              ><Icon name="simple-icons:linkedin" />LinkedIn</a
            >
          </p>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact__success {
    background: rgba(127, 222, 255, 0.18);
    border-left: 3px solid var(--cyan);
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    margin: 1.5rem 0;
    font-weight: 500;
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1.6fr 0.8fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    margin-top: 2.5rem;
    align-items: start;
  }
  .contact__direct {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .contact__direct h3 {
    margin-top: 0;
  }
  .contact__link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .contact__link svg {
    width: 1.05em;
    height: 1.05em;
    transition: transform 0.2s ease;
  }
  .contact__link:hover svg {
    transform: scale(1.12);
  }
  @media (max-width: 760px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
