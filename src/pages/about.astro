---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/AboutSection.astro";
import PdfEmbed from "../components/PdfEmbed.astro";
import { Icon } from "astro-icon/components";
import aboutPhoto from "../assets/miranda-3.jpg";
import { LINKEDIN } from "../lib/site";

const resumePdf = "/pdfs/miranda-morton-resume.pdf";

const letters = [
  {
    title: "Letter of Recommendation",
    from: "Erik Jansson",
    href: "/pdfs/letter-jansson.pdf",
  },
  {
    title: "Professional Reference",
    from: "Janet Eibes",
    href: "/pdfs/reference-eibes.pdf",
  },
];
---

<Layout title="About - Miranda Morton">
  <section class="section">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>About Me</h1>
      <AboutSection variant="full" image={aboutPhoto} showResumeCta={false} />
      <p class="about__links">
        <a href={LINKEDIN} target="_blank" rel="noopener" class="btn btn--ghost">
          <Icon name="simple-icons:linkedin" />View LinkedIn
        </a>
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2>Resume</h2>
      <p class="lede">Read it below or download a copy.</p>
      <div class="about__resume">
        <PdfEmbed
          src={resumePdf}
          title="Miranda Morton — Resume"
          ratio="page"
          downloadLabel="Download Resume (PDF)"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Letters of Recommendation</h2>
      <p class="lede">References from colleagues and mentors.</p>
      <div class="letters">
        {
          letters.map((letter) => (
            <div class="letter">
              <h3 class="letter__title">
                {letter.title} — {letter.from}
              </h3>
              <PdfEmbed
                src={letter.href}
                title={`${letter.title} — ${letter.from}`}
                ratio="page"
                downloadLabel="Download (PDF)"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .about__links {
    margin-top: 2rem;
  }
  .about__resume {
    margin-top: 2rem;
  }
  .letters {
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    align-items: start;
  }
  .letter__title {
    margin: 0 0 1rem;
    font-size: 1.2rem;
    color: var(--navy);
  }
</style>
