---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/AboutSection.astro";
import PdfEmbed from "../components/PdfEmbed.astro";

const resumePdf = "/pdfs/miranda-morton-resume.pdf";
const linkedin = "https://www.linkedin.com/in/miranda-morton-34b00230a/";

// Update these as needed — pulled from the resume.
const experience = [
  {
    role: "Architectural Designer & Drafter",
    org: "JLA Architects",
    dates: "2022 – Present",
    note: "Design coordination and construction documentation for multifamily and affordable housing projects.",
  },
  {
    role: "Administrative Assistant",
    org: "The Mulhern Group, Ltd.",
    dates: "2025 – Present",
    note: "Supporting day-to-day operations of an architecture practice.",
  },
];
---

<Layout title="About — Miranda Morton">
  <section class="section">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>About Miranda</h1>
      <AboutSection variant="full" showResumeCta={false} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2>Experience</h2>
      <ul class="exp">
        {
          experience.map((job) => (
            <li class="exp__item">
              <div class="exp__head">
                <span class="exp__role">{job.role}</span>
                <span class="exp__dates">{job.dates}</span>
              </div>
              <p class="exp__org">{job.org}</p>
              <p class="exp__note">{job.note}</p>
            </li>
          ))
        }
      </ul>
      <p class="about__links">
        <a href={linkedin} target="_blank" rel="noopener" class="btn btn--ghost">
          View LinkedIn →
        </a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Resume</h2>
      <p class="lede">Read it below or download a copy.</p>
      <div class="about__resume">
        <PdfEmbed
          src={resumePdf}
          title="Miranda Morton — Resume"
          ratio="page"
          downloadLabel="Download Resume (PDF)"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  .exp {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    gap: 1.25rem;
    max-width: 760px;
  }
  .exp__item {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .exp__head {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
  }
  .exp__role {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--navy);
  }
  .exp__dates {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .exp__org {
    margin: 0.15rem 0 0.5rem;
    color: var(--accent-strong);
    font-weight: 500;
  }
  .exp__note {
    margin: 0;
    color: var(--text-muted);
  }
  .about__links {
    margin-top: 2rem;
  }
  .about__resume {
    margin-top: 2rem;
  }
</style>
